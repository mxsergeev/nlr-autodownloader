generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum QueryStatus {
  pending
  fetching_metadata
  fetching_results
  download_queued
  downloading
  completed
  download_blocked
  search_failed
  paused
}

model Query {
  id               Int         @id @default(autoincrement())
  pageUrl          String      @unique
  searchUrl        String?
  status           QueryStatus @default(pending)
  results          Int?
  resultsPerPart   Int?
  parts            Int?
  /// Numeric sort key — stored as Date.now() + offset, so needs BigInt
  order            BigInt      @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  lastAttempt      DateTime?
  downloaded       Int         @default(0)
  downloadProgress String?

  searchResults SearchResult[]
}

model SearchResult {
  id       Int    @id @default(autoincrement())
  title    String
  href     String
  fileName String

  queryId Int
  query   Query @relation(fields: [queryId], references: [id], onDelete: Cascade)

  status QueryStatus @default(pending)

  @@unique([queryId, href])
}
